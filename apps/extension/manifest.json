{
  "manifest_version": 3,
  "name": "CTX",
  "description": "Portable memory for AI workflows.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://notebooklm.google.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.deepseek.com/*",
    "https://grok.com/*",
    "https://poe.com/*",
    "https://chat.mistral.ai/*",
    "https://copilot.microsoft.com/*",
    "https://*.copilot.microsoft.com/*",
    "https://www.meta.ai/*",
    "https://chat.qwen.ai/*",
    "https://qwen.ai/*",
    "https://*.qwen.ai/*",
    "https://lovable.dev/*",
    "https://*.lovable.dev/*",
    "https://replit.com/*",
    "https://app.emergent.sh/*",
    "https://v0.dev/*",
    "https://bolt.new/*",
    "https://cursor.com/*",
    "https://github.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "CTX",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://notebooklm.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*",
        "https://poe.com/*",
        "https://chat.mistral.ai/*",
        "https://copilot.microsoft.com/*",
        "https://*.copilot.microsoft.com/*",
        "https://www.meta.ai/*",
        "https://chat.qwen.ai/*",
        "https://qwen.ai/*",
        "https://*.qwen.ai/*",
        "https://lovable.dev/*",
        "https://*.lovable.dev/*",
        "https://replit.com/*",
        "https://app.emergent.sh/*",
        "https://v0.dev/*",
        "https://bolt.new/*",
        "https://cursor.com/*",
        "https://github.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/ctx-mark.png"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://notebooklm.google.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*",
        "https://poe.com/*",
        "https://chat.mistral.ai/*",
        "https://copilot.microsoft.com/*",
        "https://*.copilot.microsoft.com/*",
        "https://www.meta.ai/*",
        "https://chat.qwen.ai/*",
        "https://qwen.ai/*",
        "https://*.qwen.ai/*",
        "https://lovable.dev/*",
        "https://*.lovable.dev/*",
        "https://replit.com/*",
        "https://app.emergent.sh/*",
        "https://v0.dev/*",
        "https://bolt.new/*",
        "https://cursor.com/*",
        "https://github.com/*"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
