{
  "name": "@ctx/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "prisma generate && next build",
    "lint": "eslint app components lib tests",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db execute --schema prisma/schema.prisma --file prisma/schema.sql && prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db execute --schema prisma/schema.prisma --file prisma/reset.sql && prisma db execute --schema prisma/schema.prisma --file prisma/schema.sql && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ctx/core": "workspace:*",
    "@prisma/client": "^6.8.2",
    "lucide-react": "^0.468.0",
    "next": "^14.2.28",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
